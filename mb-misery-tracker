// ------------------------------------------------------------
// 2. TRACKER STATE
// ------------------------------------------------------------
// Roll20's `state` object remembers things between sessions.
// This function makes sure the tracker exists and has the right shape.

function getTracker() {
  if (!state.MB_MiseryTracker) {
    state.MB_MiseryTracker = {};
  }

  if (!Array.isArray(state.MB_MiseryTracker.active)) {
    state.MB_MiseryTracker.active = [];
  }

  if (typeof state.MB_MiseryTracker.finalTriggered !== "boolean") {
    state.MB_MiseryTracker.finalTriggered = false;
  }

  return state.MB_MiseryTracker;
}


// ------------------------------------------------------------
// 3. OUTPUT HELPERS
// ------------------------------------------------------------
// These functions help format what Roll20 says back to you.

function whisperGM(message) {
sendChat("Misery Tracker", "/w gm " + message);
}

function sayPublic(message) {
sendChat("Misery Tracker", message);
}

function box(title, body) {
return (
"<div style='border:1px solid #6f1d1b; background:#1a1111; color:#f2e6d8; padding:10px; font-family:Georgia, serif;'>" +
"<div style='font-size:16px; font-weight:bold; color:#d6a24a; margin-bottom:6px;'>" + title + "</div>" +
"<div style='font-size:13px; line-height:1.35;'>" + body + "</div>" +
"</div>"
);
}

function smallButton(label, command) {
return (
"<a href='" + command + "' style='background:#3b1f1f; color:#f2e6d8; border:1px solid #d6a24a; padding:4px 7px; text-decoration:none; font-weight:bold; display:inline-block; margin:2px 0;'>" +
label +
"</a>"
);
}

function commandHelpRow(label, command, description) {
return (
"<div style='margin-bottom:9px;'>" +
smallButton(label, command) +
"<div style='font-size:12px; color:#c9b99a; margin-top:2px;'>" + description + "</div>" +
"</div>"
);
}

function formatMiseryLine(id) {
const misery = MISERIES[id];

if (!misery) {
return (
"<div style='border-left:3px solid #777; padding-left:8px; margin-bottom:8px;'>" +
"<b>" + id + " - Unknown Misery</b>" +
"</div>"
);
}

return (
"<div style='border-left:3px solid #d6a24a; padding-left:8px; margin-bottom:10px;'>" +
"<div style='font-weight:bold; color:#d6a24a;'>" + id + " - " + misery.title + "</div>" +
"<div style='margin-top:3px;'>" + misery.text + "</div>" +
"</div>"
);
}

function getRollableMiseryIds() {
return Object.keys(MISERIES).filter(function(id) {
return MISERIES[id].final !== true;
});
}

function getRemainingMiseryIds() {
const tracker = getTracker();
const rollableIds = getRollableMiseryIds();

return rollableIds.filter(function(id) {
return !tracker.active.includes(id);
});
}

function hasReachedMiseryCap() {
const tracker = getTracker();
return tracker.active.length >= MAX_ACTIVE_MISERIES;
}

function rollMisery() {
const tracker = getTracker();

if (hasReachedMiseryCap()) {
whisperGM(
box(
"Misery Cap Reached",
"Six Miseries are already active.<br><br>" +
"Use <b>!mb-misery final</b> when you are ready to trigger Psalm 7:7."
)
);
return;
}

const remainingIds = getRemainingMiseryIds();

if (remainingIds.length === 0) {
whisperGM(
box(
"No Rollable Miseries Remain",
"The final Misery has not been triggered automatically.<br><br>" +
"Use <b>!mb-misery final</b> when you are ready to end the world."
)
);
return;
}

const randomIndex = randomInteger(remainingIds.length) - 1;
const miseryId = remainingIds[randomIndex];

tracker.active.push(miseryId);

whisperGM(
box(
"Rolled Misery",
formatMiseryLine(miseryId) +
"<br><b>Misery Clock:</b> " + tracker.active.length + "/" + MAX_ACTIVE_MISERIES
)
);
}

function showHelp() {
const body =
commandHelpRow("HELP", "!mb-misery help", "Show this command menu.") +
commandHelpRow("LIST", "!mb-misery list", "Show the full GM-facing tracker with active Miseries and final status.") +
commandHelpRow("PLAYER TRACKER", "!mb-misery player", "Post a public, player-facing Misery tracker to the chat.") +
commandHelpRow("ROLL", "!mb-misery roll", "Roll a new random Misery. Already-active Miseries cannot be rolled again.") +
commandHelpRow("ADD 1:6", "!mb-misery add", "Manually add a specific Misery by psalm key. Replace 1:6 with the desired key.") +
commandHelpRow("REMOVE 1:6", "!mb-misery remove", "Remove an active Misery by psalm key. Replace 1:6 with the desired key.") +
commandHelpRow("RESET", "!mb-misery reset", "Ask for confirmation, then clear all active Miseries and final status.") +
commandHelpRow("FINAL", "!mb-misery final", "Ask for confirmation, then trigger Psalm 7:7.");

whisperGM(box("MÖRK BORG Misery Tracker", body));
}

function showList() {
const tracker = getTracker();

let body =
"<b>Misery Clock:</b> " + tracker.active.length + "/" + MAX_ACTIVE_MISERIES + "<br>" +
"<b>Final Misery:</b> " + (tracker.finalTriggered ? "Triggered" : "Pending") + "<br><br>";

if (tracker.active.length === 0) {
body += "<i>No Miseries are currently active.</i>";
whisperGM(box("Active Miseries", body));
return;
}

tracker.active.forEach(function(id) {
body += formatMiseryLine(id);
});

whisperGM(box("Active Miseries", body));
}

function showPlayerTracker() {
const tracker = getTracker();

let body =
"<b>Misery Clock:</b> " + tracker.active.length + "/" + MAX_ACTIVE_MISERIES + "<br><br>";

if (tracker.active.length === 0) {
body += "<i>No Miseries are currently active.</i>";
sayPublic(box("The Miseries", body));
return;
}

tracker.active.forEach(function(id) {
body += formatMiseryLine(id);
});

if (tracker.finalTriggered) {
body +=
"<div style='border-left:3px solid #9b111e; padding-left:8px; margin-top:10px;'>" +
"<div style='font-weight:bold; color:#9b111e;'>Psalm 7:7 - The Final Misery</div>" +
"<div style='margin-top:3px;'>All praise Yetsabu-Nech, the underworld’s nightmare, the black disk which stands before the sun! All praise Verhu, beaming with delight! All praise the fire which burns all! And the darkness shall swallow the darkness.</div>" +
"</div>";
}

sayPublic(box("The Miseries", body));
}

function showResetConfirmation() {
const body =
"This will clear all active Miseries and reset the final Misery flag.<br><br>" +
smallButton("YES, RESET", "!mb-misery reset confirm") +
" " +
smallButton("Cancel", "!mb-misery reset cancel");

whisperGM(box("Reset Misery Tracker?", body));
}

function showFinalConfirmation() {
const tracker = getTracker();

let warning = "";

if (tracker.active.length < MAX_ACTIVE_MISERIES) {
warning =
"<b>Warning:</b> Fewer than six Miseries are active.<br>" +
"<b>Active Miseries:</b> " + tracker.active.length + "/" + MAX_ACTIVE_MISERIES + "<br><br>";
}

const body =
warning +
"This will trigger Psalm 7:7 and mark the end of the Misery cycle.<br><br>" +
smallButton("YES, END THE WORLD", "!mb-misery final confirm") +
" " +
smallButton("Cancel", "!mb-misery final cancel");

whisperGM(box("Trigger Final Misery?", body));
}



